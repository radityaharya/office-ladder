# Postgres (Supabase — prefer session pooler for broad compatibility)
# Encode special characters in the password: & %26, $ %24, @ %40
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Supabase (DB + Realtime — not used for auth)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""

# Better Auth
# openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3072"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3072"
